<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cobra.controllers.DashboardController">

    <top>
        <Label text="Budget Tracker" style="-fx-font-size: 24px; -fx-padding: 20;" />
    </top>

    <center>
<!--        <Label text="Transactions will go here" />-->
        <VBox spacing = "20" style="-fx-padding: 20;">
            <!-- Transactions Table -->
            <Label text = "Transactions" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TableView fx:id="TransactionTable" prefHeight="200">
                <columns>
                    <TableColumn text="ID" prefWidth="50"/>
                    <TableColumn text="Category" prefWidth="150"/>
                    <TableColumn text="Amount" prefWidth="150"/>
                </columns>
            </TableView>
            <!-- Goals Table -->
            <Label text="Goals" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TableView fx:id="Goal" prefHeight="200">
                <columns>
                    <TableColumn text="ID" prefWidth="50"/>
                    <TableColumn text="Category" prefWidth="150"/>
                    <TableColumn text="Amount" prefWidth="150"/>
                    <TableColumn text="Date" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>