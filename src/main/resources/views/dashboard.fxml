<?xml version="1.0" encoding="UTF-8"?>

<!-- required jfx layout and control stuffs -->
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.Button?>

<!-- linked to dash controller (fx:controller) -->
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cobra.Controller">

    <!-- top nav bar placeholder -->
    <top>
        <Label text="CoBRA" style="-fx-font-size: 24px; -fx-padding: 20;" />
    </top>

    <center>
        <!-- main content area, vertical stacking widgets -->
        <VBox spacing = "20" style="-fx-padding: 20;">
            <Button text="+ Add" onAction="#onAddTransaction" style="-fx-background-color: #e94560; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <Button text="Edit" onAction="#onEditTransaction" style="-fx-background-color: #f5a623; -fx-text-fill: white; -fx-font-weight: bold;"/>
            <!--
            Transactions Table
            fx:id must match @FXML field names in dash controller
            data populated in .initialize
            this also applies to Goals Table (see below)
            -->
            <Label text = "Transactions" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TableView fx:id="TransactionTable" prefHeight="200">
                <columns>
                    <TableColumn fx:id="TransactionIDCol" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="TransactionCategoryCol" text="Category" prefWidth="150"/>
                    <TableColumn fx:id="TransactionAmountCol" text="Amount" prefWidth="150"/>
                    <TableColumn fx:id="TransactionDateCol" text="Date" prefWidth="150"/>
                </columns>
            </TableView>
            <!-- Goals Table -->
            <Label text="Goals" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <TableView fx:id="GoalTable" prefHeight="200">
                <columns>
                    <TableColumn fx:id="GoalIDCol" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="GoalCategoryCol" text="Category" prefWidth="150"/>
                    <TableColumn fx:id="GoalAmountCol" text="Amount" prefWidth="150"/>
                    <TableColumn fx:id="GoalDateCol" text="Date" prefWidth="150"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
