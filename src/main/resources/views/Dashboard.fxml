<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.cobra.DashboardView"
      spacing="16"
      style="-fx-padding: 24;, -fx-background-color: #f4f4f4;">

    <!-- header -->
    <Label text="STRIVE — Budget Tracker"
           style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #333;"/>

    <!-- quick/test input box -->
    <TitledPane text="Quick Add Transaction" collapsible="false"
                style="-fx-font-weight: bold;">
        <GridPane hgap="12" vgap="8">
            <padding>
                <Insets top="8" right="8" bottom="8" left="8"/>
            </padding>

            <Label text="Amount ($):"
                   GridPane.columnIndex="0"
                   GridPane.rowIndex="0"/>
            <TextField fx:id="testAmountField"
                       promptText="e.g. 42.50"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="0"
                       prefWidth="180"/>

            <Label text="Category:"
                   GridPane.columnIndex="0"
                   GridPane.rowIndex="1"/>
            <TextField fx:id="testCategoryField"
                       promptText="e.g. Food"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="1"
                       prefWidth="180"/>

            <Button text="Submit"
                    onAction="#onTestSubmitClicked"
                    GridPane.columnIndex="1"
                    GridPane.rowIndex="2"
                    style="-fx-background-color: #4CAF50; -fx-text-fill: white"/>

            <Label fx:id="statusLabel"
                   text=""
                   style="-fx-text-fill: #555;"
                   GridPane.columnIndex="0"
                   GridPane.rowIndex="2"
                   GridPane.columnSpan="2"/>
        </GridPane>
    </TitledPane>

    <!-- Transaction list -->
    <Label text="Transactions"/>
    <ListView fx:id="transactionListView"
              prefHeight="300"
              style="-fx-font-family: monospace;"/>

    <!-- action buttons -->
    <HBox spacing="12">
        <Button text="Add Transaction (Dialog)"
                onAction="#onAddTransactionClicked"
                style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Delete Selected"
                onAction="#onDeleteSelectedClicked"
                style="-fx-background-color: #F44336; -fx-text-fill: white;"/>
    </HBox>

</VBox>